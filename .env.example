# DAD War Room — environment variables
#
# Copy to .env.local and fill in your own Supabase credentials.
# See DEPLOY.md for the production setup (Supabase secrets + Vercel env vars).

# Supabase project URL (public). Settings -> API -> Project URL.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon public key. Settings -> API -> anon public.
# Safe to expose to the browser; RLS gates every read/write.
VITE_SUPABASE_ANON_KEY=

# Web Push public key (paired with VAPID_PRIVATE_KEY stored as a Supabase
# secret on the send-push Edge Function — never put the private key here).
# Generate with: npx web-push generate-vapid-keys
# Wave 3 already generated yours — see WAR_ROOM_LOG.md §2.13 and DEPLOY.md.
VITE_VAPID_PUBLIC_KEY=BH64P-muxhIzCFlXjzFw_qVD-UpRwGAHafhZTVYqCLbJIIiuSNeBVUfaLXQXqaAgj77kZukz1E05nHZOFBJ-Ph4

# --- i18n auto-translate (free forever, no signup) ---
# Used by `npm run i18n:translate` — fills missing keys in src/locales/*.json
# from en.json. NOT loaded at runtime by the app — only by the script.
#
# DEFAULT: MyMemory (zero setup, anonymous, 5K chars/day per IP).
# Add your email below to bump to 50K chars/day (still free, no signup):
MYMEMORY_EMAIL=
#
# OPTIONAL: LibreTranslate (faster batches, self-host = unlimited):
#   docker run -it --rm -p 5000:5000 libretranslate/libretranslate
# Then set: LIBRETRANSLATE_URL=http://localhost:5000
# Public instances often require an API key now — get one at portal.libretranslate.com
# LIBRETRANSLATE_URL=
# LIBRETRANSLATE_API_KEY=
